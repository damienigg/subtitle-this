# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — first-boot defaults only.
#
# The canonical configuration surface for Subtitle This is the WEB UI at :8765/
# (Settings page). Everything below is just a way to seed initial values for
# declarative deployments (TrueNAS Custom App YAML, GitOps, etc.) — the moment
# you click "Save settings" in the UI, the UI overrides any of these values.
# You can leave this entire file empty if you prefer to configure from the UI.
# ─────────────────────────────────────────────────────────────────────────────

# ── Container runtime / host integration ─────────────────────────────────────
# Container user. Default is the image's `app` user (UID/GID 568, matching
# TrueNAS Scale's apps user). Override if your host uses a different UID —
# e.g. PUID=1000 PGID=1000 on vanilla Ubuntu. Set both to 0 for root.
PUID=568
PGID=568

# Render group GID on the HOST (for iGPU passthrough). Find with:
#   getent group render | cut -d: -f3
RENDER_GID=107

# Image flavor when pulling from GHCR: cpu | openvino
IMAGE_FLAVOR=openvino

# Required only when using the GHCR `image:` line in docker-compose.yml.
# Set this to the GitHub username or org that owns the published images.
GHCR_OWNER=

# ── First-boot seeds for the Settings UI (all optional) ──────────────────────
# Whisper backend: cpu (faster-whisper) | openvino (Intel iGPU)
BABEL_WHISPER_BACKEND=openvino
BABEL_WHISPER_MODEL=small
BABEL_OPENVINO_DEVICE=GPU

# Translation LLM slot — set these only if you want the container to start
# pre-configured. Otherwise leave them and configure from Settings → Translation
# model after first boot.
# BABEL_TRANSLATION_LLM_TYPE=anthropic                # anthropic | openai_compat
# BABEL_TRANSLATION_LLM_MODEL=claude-opus-4-7
# BABEL_TRANSLATION_LLM_ENDPOINT=https://api.openai.com/v1
# BABEL_TRANSLATION_LLM_API_KEY=

# Optional: DeepL API key (free tier: 500k chars/month).
# Free-tier keys end in ":fx" — the app auto-detects free vs paid endpoint.
# BABEL_DEEPL_API_KEY=

# ── Vocal isolation (Demucs) ────────────────────────────────────────────────
# Pre-STT phase that splits audio into stems and feeds only the VOCALS stem
# to Whisper. Closes the "climax dialog buried under music" gap on
# score-heavy films. Off by default — turn on per-film as needed.
#
# Mode: off | chunked | full
# - chunked = safe RAM (~1 GB peak, regardless of film length)
# - full    = best quality, needs ≥ 12 GB free RAM
# BABEL_VOCAL_ISOLATION_MODE=off
# BABEL_VOCAL_ISOLATION_CHUNK_SECONDS=300

# ── Resource safety knobs ────────────────────────────────────────────────────
# These bound in-process memory + runtime so a single job can't OOM the
# host. The kernel-side cgroup limits in docker-compose.yml are the real
# fence; these settings just reduce the chance of ever hitting it.
#
# Per-job wall-clock cap (seconds). 0 disables. 5400 = 90 min.
# BABEL_JOB_TIMEOUT_SECONDS=5400
#
# Audio is processed in N-second segments by the OpenVINO STT backend.
# 600s ≈ 10 min ≈ 75 MB resident at a time instead of ~500 MB for the
# whole 2 h film. Ignored by the CPU/`faster-whisper` backend (streams
# from disk on its own).
# BABEL_STT_AUDIO_SEGMENT_SECONDS=600
#
# Forward overlap on each segment read (seconds) so a speech region
# straddling the segment boundary is processed in full within one
# segment instead of being split. 30s ≈ one decoder window. Costs
# ~1.9 MB extra peak RAM during the read.
# BABEL_STT_SEGMENT_OVERLAP_SECONDS=30
#
# Pack multiple short speech regions into shared 30 s decoder windows
# with brief silence pads between, then demultiplex cues back to
# original timestamps. Cuts iGPU work 1.5-3× on dialog-heavy films.
# Flip to false as an escape hatch if a specific film shows
# misattributed cues at region boundaries.
# BABEL_STT_REGION_PACKING=true
# BABEL_STT_MAX_REGIONS_PER_WINDOW=4

# ── Optional auth ────────────────────────────────────────────────────────────
# HTTP Basic auth in front of every endpoint except /health. Leave blank
# (default) to keep the zero-config first-boot experience. Set this on
# any network where you wouldn't trust every device to start jobs or
# read your API keys. Format: "user:password".
# BABEL_AUTH_CREDENTIALS=

# ── Optional in-app updater ─────────────────────────────────────────────────
# Shell command run when the user clicks "Update now" on the dashboard.
# Unset (default) hides the button — clicking "Check for updates" still
# surfaces the version comparison + copy-paste commands. Set to something
# like:
#   BABEL_UPDATE_COMMAND="cd /mnt/.../subtitle-this && git pull && docker compose pull && docker compose up -d"
# to enable the in-place updater. Requires whatever privileges the
# container has — typically docker-socket access (mount /var/run/docker.sock).
# BABEL_UPDATE_COMMAND=

# Media server bootstrap (Emby + Jellyfin share the same fields; Plex
# uses BABEL_MEDIA_SERVER_TYPE=plex and pastes the X-Plex-Token into
# BABEL_MEDIA_SERVER_API_KEY). Easier to set from Settings, but pre-
# configurable for declarative deploys.
# BABEL_MEDIA_SERVER_TYPE=emby
# BABEL_MEDIA_SERVER_URL=http://emby:8096
# BABEL_MEDIA_SERVER_API_KEY=
